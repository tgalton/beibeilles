    "device_serial": "ESP32-RUCHE-001",
    "measurements": [
      {
        "type": "weight",
        "value": 12.3,
        "hive_level_id": 1
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
